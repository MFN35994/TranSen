rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction d'aide pour vérifier l'authentification
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION USERS ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      
      // Sous-collection des avis laissés par l'utilisateur
      match /my_reviews/{reviewId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- COLLECTION REVIEWS (GLOBAL) ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    // --- COLLECTIONS DE COURSES (VTC & Covoiturage) ---
    match /pools/{poolId} {
      allow read, write: if request.auth != null;
    }
    
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }

    match /active_drivers/{driverId} {
      allow read, write: if request.auth != null;
    }

    match /driver_routes/{driverId} {
      allow read, write: if request.auth != null;
    }
  }
}
