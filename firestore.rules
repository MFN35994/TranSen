rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction d'aide pour vérifier l'authentification
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION USERS ---
    match /users/{userId} {
      // Tout utilisateur connecté peut lire les profils
      allow read: if isSignedIn();
      // Seul l'utilisateur peut créer/modifier son propre document
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTIONS DE COURSES (VTC & Covoiturage) ---
    match /pools/{poolId} {
      allow read, write: if request.auth != null;
    }
    
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }

    match /active_drivers/{driverId} {
      allow read, write: if request.auth != null;
    }

    match /driver_routes/{driverId} {
      allow read, write: if request.auth != null;
    }
  }
}
